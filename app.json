{
  "name": "RallyApp",
  "displayName": "Rally",
  "expo": {
    "name": "Rally",
    "slug": "rallyapp",
    "version": "1.0.0",
    "icon": "./assets/branding/icon-1024.png",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/branding/icon-1024.png",
      "resizeMode": "cover",
      "backgroundColor": "#F5F4F0"
    },
    "ios": {
      "bundleIdentifier": "com.rallyapp",
      "supportsTablet": true,
      "icon": "./assets/branding/icon-1024.png",
      "buildNumber": "20",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "entitlements": {
        "aps-environment": "production"
      }
    },
    "android": {
      "package": "app.rally.sports",
      "icon": "./assets/branding/icon-1024.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/branding/icon-android-foreground.png",
        "backgroundColor": "#F5F4F0"
      },
      "softwareKeyboardLayoutMode": "resize",
      "versionCode": 20
    },
    "extra": {
      "eas": {
        "projectId": "c8adc581-8790-4de6-8c81-c4a49d291ffe"
      }
    },
    "owner": "kendrewpoon",
    "plugins": [
      "expo-asset",
      "expo-font"
    ]
  }
}
