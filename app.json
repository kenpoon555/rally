{
  "name": "RallyApp",
  "displayName": "Rally",
  "expo": {
    "name": "Rally",
    "slug": "rallyapp",
    "version": "1.0.0",
    "icon": "./assets/branding/icon-1024.png",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/branding/icon-1024.png",
