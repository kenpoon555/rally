{
  "cli": {
    "version": ">= 13.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "APP_ENV": "development"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "APP_ENV": "preview",
        "EXPO_PUBLIC_ENABLE_COACH_FOUNDATION": "true",
        "EXPO_PUBLIC_ENABLE_PARENT_STUDENT_CORE": "true",
        "EXPO_PUBLIC_ENABLE_PARENT_PILOT": "true",
        "EXPO_PUBLIC_ENABLE_COACH_OPS": "true"
      }
    },
    "production": {
      "env": {
        "APP_ENV": "production",
        "EXPO_PUBLIC_ENABLE_COACH_FOUNDATION": "true",
        "EXPO_PUBLIC_ENABLE_PARENT_STUDENT_CORE": "true",
        "EXPO_PUBLIC_ENABLE_PARENT_PILOT": "true",
        "EXPO_PUBLIC_ENABLE_COACH_OPS": "true"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "track": "internal"
      },
      "ios": {
        "appleId": "kunyupoon495@gmail.com",
        "appleTeamId": "68JKW6NXF6",
        "ascAppId": "6777569179"
      }
    }
  }
}
