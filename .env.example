# Required
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Optional: Places + Map
# GOOGLE_PLACES_API_KEY=
# GOOGLE_PLACES_API_KEY_IOS=
# GOOGLE_PLACES_API_KEY_ANDROID=
# GOOGLE_PLACES_MIN_INTERVAL_MS=2000
# GOOGLE_PLACES_SESSION_MAX_REQUESTS=12
# GOOGLE_PLACES_CACHE_TTL_MS=300000

# Optional: location/geofence
# GEOFENCE_RADIUS=50
# LOCATION_UPDATE_INTERVAL=10000
# LOCATION_DISTANCE_FILTER=50

# EAS Build — set these as EAS secrets (not committed to git):
#   eas secret:create --scope project --name SUPABASE_URL --value "..."
#   eas secret:create --scope project --name SUPABASE_ANON_KEY --value "..."
# Secrets set in EAS are injected as env vars during cloud builds.

# Optional: beta install links (invite landing page + in-app share fallbacks)
# IOS_INSTALL_URL=https://testflight.apple.com/join/gBcW7gA2
# ANDROID_INSTALL_URL=https://play.google.com/store/apps/details?id=app.rally.sports
# For Play internal testers, use the opt-in link from Play Console → Internal testing.
# Also set on Supabase: supabase secrets set IOS_INSTALL_URL=... ANDROID_INSTALL_URL=...

# Optional: Sentry (crash reporting) — public DSN is ok in client; still via env:
# SENTRY_DSN=

# Optional: seed scripts (local only — never commit)
# SUPABASE_SERVICE_ROLE_KEY=
# Used by seed scripts only (scripts/seed-monrovia-basketball-rally-demo.mjs, seed-la-courts.mjs).
# Get from Supabase Dashboard → Project Settings → API → service_role (secret).

# Optional: debug ingest to local host (dev only)
# EXPO_PUBLIC_ENABLE_DEBUG_INGEST=true

# Optional: show location debug panel on Discover (dev builds only)
# EXPO_PUBLIC_SHOW_LOCATION_DEBUG=true

# Coach/parent/student UI bundles (default off in code; enable for local dev or EAS builds).
# EAS preview + production profiles set all four to true for closed beta testers (see eas.json).
# Uncomment locally to match TestFlight / Play internal builds:
# EXPO_PUBLIC_ENABLE_COACH_FOUNDATION=true
# EXPO_PUBLIC_ENABLE_PARENT_STUDENT_CORE=true
# EXPO_PUBLIC_ENABLE_PARENT_PILOT=true
# EXPO_PUBLIC_ENABLE_COACH_OPS=true
